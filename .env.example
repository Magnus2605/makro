# Kopiér til .env og tilpas (filen indlæses automatisk af server.py hvis den findes).
# Indsæt aldrig API-nøgler eller hemmeligheder her — DST StatBank kræver ikke login til åbne data.

PORT=3000

# Netværksinterface serveren binder til (127.0.0.1 = kun denne maskine; 0.0.0.0 = alle interfaces — kun bag firewall/reverse proxy).
HOST=127.0.0.1

# Cache-levetid for makro-JSON i sekunder (standard 6 timer).
CACHE_TTL_SECONDS=21600

# Valgfri: kun hvis du vil pege mod mock eller proxy (normalt uændret).
# DST_API_URL=https://api.statbank.dk/v1/data

# Valgfri: hvilken Python-binary der bruges når du kører `npm start` (node server.js).
# PYTHON=python3
